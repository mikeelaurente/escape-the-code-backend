                        <li class="sidebar-item">
                          <a class="sidebar-link" href="#">Item 1</a>
                        </li>
                        <li class="sidebar-item">
                          <a class="sidebar-link" href="#">Item 2</a>
                        </li>
                      </ul>
                    </li>
                    <li class="sidebar-item">
                      <a class="sidebar-link" href="#">Item 2</a>
                    </li>
                  </ul>
                </li>
              </ul>
            </li>
          </ul>
